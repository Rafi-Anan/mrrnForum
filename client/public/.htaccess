Options -MultiViews
RewriteEngine On
RewriteBase /

# Serve the app shell for client-side routes so browser refreshes work on Hostinger.
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

ErrorDocument 404 /index.html
